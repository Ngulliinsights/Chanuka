# ============================================================================
# Chanuka Platform — Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!
# Last Updated: March 6, 2026
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Primary database connection
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Test database (used during test runs)
TEST_DATABASE_URL="postgresql://username:password@host:port/test_database?sslmode=require"

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment: development | production | test
NODE_ENV=development

# Server port
PORT=4200

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# ⚠️ CRITICAL: Change these in production! Use strong random values.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# JWT secret for authentication tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session secret for session management
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Encryption key for PII data (32 bytes for AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key-change-in-production

# PII encryption key (alternative name, same purpose)
PII_ENCRYPTION_KEY=your-32-byte-pii-encryption-key-change-in-production

# Key derivation salt for password hashing
KEY_DERIVATION_SALT=your-key-derivation-salt-change-in-production

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API base URL (server-side)
API_BASE_URL=http://localhost:4200/api

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Debug test output (true | false)
DEBUG_TESTS=false

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Cache provider: memory | redis
CACHE_PROVIDER=memory

# Bill cache TTL (seconds)
BILL_CACHE_TTL=3600

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit provider: memory | redis
RATE_LIMIT_PROVIDER=memory

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Core features
ENABLE_ANALYTICS=true
ENABLE_REAL_TIME=true
ENABLE_NOTIFICATIONS=true

# Bill features
ENABLE_BILL_TRANSLATIONS=true
ENABLE_VOTING_PATTERNS=true
ENABLE_REAL_TIME_TRACKING=true
ENABLE_ACTION_PROMPTS=true

# User features
ENABLE_CITIZEN_VERIFICATION=true
ENABLE_EXPERT_VERIFICATION=true

# OAuth providers
ENABLE_OAUTH_GOOGLE=false
ENABLE_OAUTH_GITHUB=false

# ============================================================================
# EMAIL CONFIGURATION (SMTP)
# ============================================================================

# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password

# From email address
FROM_EMAIL=noreply@chanuka.ke

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Verification document upload path
VERIFICATION_DOCUMENT_UPLOAD_PATH=/uploads/verification

# ============================================================================
# CLIENT-SIDE ENVIRONMENT VARIABLES
# ============================================================================
# Variables prefixed with VITE_ are accessible in the client application

# API base URL (client-side)
VITE_API_BASE_URL=http://localhost:4200/api

# Environment
VITE_NODE_ENV=development

# Debug mode
VITE_DEBUG=false

# Feature flags (client-side)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_REAL_TIME=true
VITE_ENABLE_NOTIFICATIONS=true

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

# Sentry DSN for error tracking
VITE_SENTRY_DSN=your-sentry-dsn-here

# Google Analytics ID
VITE_GOOGLE_ANALYTICS_ID=your-ga-id-here

# ============================================================================
# AI/ML SERVICES
# ============================================================================

# Gemini API key for AI features
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================================
# WEBSOCKET CONFIGURATION
# ============================================================================

# WebSocket server port (if different from main server)
# WEBSOCKET_PORT=3001

# ============================================================================
# NEO4J CONFIGURATION (Graph Database)
# ============================================================================
# Used for bill relationships and network analysis

# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password

# ============================================================================
# DEVELOPMENT TOOLS
# ============================================================================

# Enable API contract validation (development only)
# ENABLE_API_CONTRACT_VALIDATION=true

# ============================================================================
# NOTES
# ============================================================================
#
# Required for basic operation:
# - DATABASE_URL
# - JWT_SECRET
# - SESSION_SECRET
#
# Required for production:
# - All SECURITY CONFIGURATION variables (use strong random values)
# - SMTP configuration (for email notifications)
# - FRONTEND_URL (set to actual domain)
#
# Optional but recommended:
# - REDIS_URL (for production caching and rate limiting)
# - SENTRY_DSN (for error tracking)
# - GOOGLE_ANALYTICS_ID (for analytics)
#
# Feature-specific:
# - GEMINI_API_KEY (for AI features)
# - NEO4J_* (for graph database features)
# - SMTP_* (for email notifications)
# - VERIFICATION_DOCUMENT_UPLOAD_PATH (for user verification)
#
# ============================================================================