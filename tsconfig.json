{
  /**
   * ROOT TYPESCRIPPT CONFIGURATION - Monorepo Base Config
   *
   * PROJECT REFERENCES & COMPOSITE STRATEGY:
   * - Root: composite=false (coordinates workspaces, not itself a buildable project)
   * - Server (server/tsconfig.json): composite=true (builds independently, generates .tsbuildinfo)
   * - Client (client/tsconfig.json): composite=false (uses Vite bundler instead of tsc)
   * - Shared (shared/tsconfig.json): composite=true (outputs declarations for client/server)
   *
   * This strategy allows:
   * - Server: Fast incremental builds via tsc with project references
   * - Client: Leverages Vite bundler for faster dev experience
   * - Shared: Serves as typed library consumed by both
   */
  "files": [],
  "references": [
    { "path": "./client" },
    { "path": "./server" },
    { "path": "./shared" }
  ],
  "include": [],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage"
  ],
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2022",
    "lib": [
      "ES2022",
      "dom",
      "dom.iterable"
    ],
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useUnknownInCatchVariables": true,

    /* Modules */
    "module": "ES2022",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@shared": ["shared"],
      "@shared/*": ["shared/*"],
      "@server": ["server"],
      "@server/*": ["server/*"],
      "@client": ["client/src"],
      "@client/*": ["client/src/*"],
      "@tests": ["tests"],
      "@tests/*": ["tests/*"]
    },
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "allowJs": true,
    "checkJs": false,

    /* Emit */
    "declaration": true,
    "removeComments": true,
    "importHelpers": true,
    "downlevelIteration": true,
    "sourceMap": true,
    "verbatimModuleSyntax": false,

    /* Interop Constraints */
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",

    /* Type Checking - Strict Mode */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "exactOptionalPropertyTypes": false, // Disabled temporarily - causing hundreds of errors with | undefined

    /* Type Checking - Additional Checks */
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    /* Completeness */
    "skipLibCheck": true,

    /* Performance */
    "incremental": true,

    /* Type Definitions */
    "types": [
      "node",
      "vite/client",
      "vitest/globals"
    ],

    /* Composite project setup for monorepo */
    "composite": false
  }
}
